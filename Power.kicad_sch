	(text "Buck-Boost converter with 3.3V output up to 1200mAh. \n1.8-5.5V input range\n"
		(exclude_from_sim no)
		(at 92.202 21.082 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "1be13d16-aaa1-4380-bb61-68a32583c763")
	)
	(text "+8V is the 8V used for our servo motors\n\n+5VD is the 5V coming from the DC jack\n\n+5VC is the 5V coming from buck-boost (U10) for charging batts\n\n+5V is the system 5V (mainly used for LIDAR)coming from U8\n\n+3.3V is the 3.3V for peripherals and STM32 coming from U2\n \nVCC is the primary power rail as determined by the \nPMOS/NMOS power control system\n\n"
		(exclude_from_sim no)
		(at 231.902 151.384 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "30bf524e-fb72-44bf-b8a0-591aa37ac00c")
	)
